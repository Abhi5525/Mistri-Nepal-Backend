# Application
APP_NAME="Mistri Nepal API"
APP_VERSION="1.0.0"
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mistri_nepal_fastapi

# Redis
REDIS_URL=redis://localhost:6379

# JWT Settings
SECRET_KEY=your-super-secret-key-change-this-in-production-min-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
BCRYPT_ROUNDS=12

# CORS
ALLOWED_ORIGINS=["*"]

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=./uploads

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json


CLOUDINARY_CLOUD_NAME=desktop name
CLOUDINARY_API_KEY=key
CLOUDINARY_API_SECRET=secret key
CLOUDINARY_FOLDER=folder name

# eSewa Payment
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_BASE_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form